{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "dialog:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/luajit", "sidecar": true, "args": true }]
    }
  ]
}
